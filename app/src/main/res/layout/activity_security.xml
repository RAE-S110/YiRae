<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_album">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="18dp"
        android:background="@drawable/bg_card_paper"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSecurityTitle"
            style="@style/TextTitleAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/security_setup_title" />

        <TextView
            android:id="@+id/tvPrivacyHint"
            style="@style/TextNoteAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/privacy_notice" />

        <EditText
            android:id="@+id/etNickname"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_nickname" />

        <EditText
            android:id="@+id/etPassword"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_lock_password"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/etConfirmPassword"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_confirm_lock_password"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnConfirmSecurity"
            style="@style/ButtonPrimaryAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/save_and_enter" />
    </LinearLayout>
</ScrollView>
