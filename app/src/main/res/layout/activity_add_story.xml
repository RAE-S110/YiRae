<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_album">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_paper"
        android:layout_margin="18dp"
        android:orientation="vertical"
        android:padding="18dp">

        <EditText
            android:id="@+id/etTitle"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title" />

        <TextView
            style="@style/TextNoteAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_pick_date" />

        <Button
            android:id="@+id/btnSelectDate"
            style="@style/ButtonSecondaryAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/select_date" />

        <TextView
            android:id="@+id/tvSelectedDate"
            style="@style/TextNoteAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/no_date_selected" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSelectTime"
                style="@style/ButtonSecondaryAlbum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/select_time_optional" />

            <Button
                android:id="@+id/btnClearTime"
                style="@style/ButtonSecondaryAlbum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/clear_time" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedTime"
            style="@style/TextNoteAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/no_time_selected" />

        <EditText
            android:id="@+id/etPlace"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_place" />

        <EditText
            android:id="@+id/etPeople"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_people" />

        <EditText
            android:id="@+id/etMemoryText"
            style="@style/InputAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:hint="@string/hint_memory"
            android:minLines="5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSelectImage"
                style="@style/ButtonPrimaryAlbum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/select_images" />

            <Button
                android:id="@+id/btnClearImages"
                style="@style/ButtonSecondaryAlbum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/clear_images" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSelectedImage"
            style="@style/TextNoteAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/no_image_selected" />

        <Button
            android:id="@+id/btnSave"
            style="@style/ButtonPrimaryAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save" />

    </LinearLayout>
</ScrollView>
