<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_album"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:fontFamily="serif"
        android:text="@string/main_title"
        android:textColor="@color/ink"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card_paper"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNickname"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:text="@string/app_name"
            android:textColor="@color/ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettings"
            style="@style/ButtonSecondaryAlbum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/local_settings" />
    </LinearLayout>

    <Button
        android:id="@+id/btnAddStory"
        style="@style/ButtonPrimaryAlbum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/add_story" />

    <Button
        android:id="@+id/btnCalendar"
        style="@style/ButtonSecondaryAlbum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/calendar_view" />

    <Button
        android:id="@+id/btnFavoriteStories"
        style="@style/ButtonSecondaryAlbum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/favorite_stories" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_paper"
        android:orientation="horizontal"
        android:padding="12dp">

        <EditText
            android:id="@+id/etSearchKeyword"
            style="@style/InputAlbum"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_search_keyword"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSearch"
            style="@style/ButtonPrimaryAlbum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/search" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSearchSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:fontFamily="serif"
        android:textColor="@color/ink_soft"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_paper"
        android:fontFamily="serif"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:text="@string/empty_story_list"
        android:textColor="@color/ink_soft"
        android:textSize="16sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listViewStories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp" />

</LinearLayout>
