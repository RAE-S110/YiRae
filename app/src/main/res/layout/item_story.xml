<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foregroundGravity="center"
    android:minHeight="96dp">

    <LinearLayout
        android:id="@+id/actionContainer"
        android:layout_width="288dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/swipeFavoriteContainer"
            android:layout_width="96dp"
            android:layout_height="match_parent"
            android:background="@color/sage"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/favorite_story"
                android:src="@android:drawable/btn_star_big_on"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvSwipeFavoriteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="serif"
                android:text="@string/favorite_story"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/swipeShareContainer"
            android:layout_width="96dp"
            android:layout_height="match_parent"
            android:background="@color/terracotta"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/share_story"
                android:src="@android:drawable/ic_menu_share"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="serif"
                android:text="@string/share_story"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deleteContainer"
            android:layout_width="96dp"
            android:layout_height="match_parent"
            android:background="@color/danger"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivDelete"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/delete_story"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="serif"
                android:text="@string/delete"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/storyForeground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_paper"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/ivItemImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/story_image"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:maxLines="1"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFavoriteBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_badge_favorite"
                android:fontFamily="serif"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="@string/favorite_badge"
                android:textColor="@color/golden_tag_text"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvItemSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="serif"
                android:maxLines="2"
                android:textColor="@color/ink_soft"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
